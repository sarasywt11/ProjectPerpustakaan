@model PerpusWebProject.Models.Peminjaman

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Peminjaman</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TanggalPinjam)
