        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Buku)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Buku.Judul)
        </dd>
        <dt class = "col-sm-2">
